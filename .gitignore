# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependency directories
node_modules/
/.pnp
.pnp.js

# Build directories
dist/
build/
out/
generated/

# Personal files
$.*
*.code-workspace
*.tsbuildinfo
.yarnrc
.yarnrc.yml

# Shell scripts
*.cmd
*.sh

# Configuration files
web.config
web.config.json
nodemon.json
nodemon.*.json

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage directory used by tools like istanbul
coverage

# dotenv environment variable files
.env
.env.*

# Temporary folders
tmp/
temp/

# Editor directories and files
.idea
.vscode
.vs/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# testing
/coverage

# local files
*.local
*.local.*
*.todo
*.todo.*
*.notes.*