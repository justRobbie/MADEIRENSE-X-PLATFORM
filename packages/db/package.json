{
    "name": "@Madeirense/database",
    "version": "1.0.0",
    "private": true,
    "main": "dist/index.js",
    "type": "module",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "generate": "prisma generate",
        "prisma": "prisma db pull && prisma generate",
        "prisma:dev": "prisma db pull --schema ./prisma/schema.dev.prisma && prisma generate --schema ./prisma/schema.dev.prisma",
        "prisma:staging": "prisma db pull --schema ./prisma/schema.staging.prisma && prisma generate --schema ./prisma/schema.staging.prisma"
    },
    "dependencies": {
        "@prisma/client": "^5.7.1",
        "dotenv": "^17.2.4"
    },
    "devDependencies": {
        "prisma": "^5.7.1",
        "tsx": "^4.6.2",
        "typescript": "^5.3.3"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./client": {
            "types": "./dist/client.d.ts",
            "import": "./dist/client.js",
            "require": "./dist/client.js"
        },
        "./browser": {
            "types": "./dist/types/browser.d.ts",
            "import": "./dist/types/browser.js",
            "default": "./dist/types/browser.js"
        }
    }
}
