{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "strict": true,
        "paths": {
            "assets": ["./assets/*"],
            "components/*": ["./components/*"],
            "configurations": ["./configurations/index.ts"],
            "configurations/*": ["./configurations/*"],
            "contexts/*": ["./contexts/*"],
            "constants/*": ["./constants/*"],
            "env": ["./env.ts"],
            "hooks/*": ["./hooks/*"],
            "services/*": ["./services/*"],
            "utilities/*": ["./utilities/*"],
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".expo/types/**/*.ts",
        "expo-env.d.ts"
    ]
}