{
    "name": "web",
    "description": "Order placement and management app for Madeirense restaurant.",
    "author": "Roberto de Carvalho @ DANCE, Madeirense, lda.",
    "version": "1.0.0",
    "license": "ISC",
    "main": "build/main.js",
    "private": true,
    "keywords": [
        "aplicação web",
        "madeirense"
    ],
    "scripts": {
        "build": "vite build",
        "build:development": "vite build --mode development",
        "build:staging": "vite build --mode staging",
        "clean": "rm -rf ./node_modules ./dist package-lock.json yarn.lock",
        "dev": "vite",
        "preview": "vite preview",
        "restart": "npm run clean && npm i && npm run build && npm run preview",
        "restart:development": "npm run clean && npm i && npm run dev",
        "restart:dry": "npm run clean && npm i"
    },
    "dependencies": {
        "@react-google-maps/api": "^2.20.6",
        "@tanstack/react-query": "^5.77.0",
        "@testing-library/jest-dom": "^5.16.5",
        "@testing-library/react": "^13.4.0",
        "@testing-library/user-event": "^13.5.0",
        "@uploadcare/react-uploader": "^1.8.1",
        "@vitejs/plugin-react": "5.1.4",
        "chart.js": "^4.5.0",
        "howler": "^2.2.4",
        "leaflet": "^1.9.4",
        "react": "^19.2.4",
        "react-chartjs-2": "^5.3.0",
        "react-dom": "^19.2.4",
        "react-icons": "^5.5.0",
        "react-leaflet": "^5.0.0-rc.2",
        "react-leaflet-cluster": "^3.1.1",
        "react-player": "^3.1.0",
        "react-router-dom": "^7.6.2",
        "react-sounds": "^1.0.25",
        "vite": "7.3.1"
    },
    "devDependencies": {
        "@types/jest": "^27.5.2",
        "@types/leaflet": "^1.9.20",
        "@types/node": "^16.18.0",
        "@types/react": "^19.1.13",
        "@types/react-dom": "^19.1.9",
        "tailwindcss": "^3.3.0",
        "tsconfig-paths-webpack-plugin": "^4.2.0",
        "typescript": "^5.0.0",
        "typescript-plugin-css-modules": "^5.2.0",
        "vite-tsconfig-paths": "^6.1.1"
    },
    "eslintConfig": {
        "extends": [
            "react-app",
            "react-app/jest"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    }
}
